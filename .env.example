# Server
NODE_ENV="development"
PORT="8080"
APP_BASE_URL="http://localhost:8080"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
AUTH_TOKEN_SECRET="change-this-secret"
AUTH_TOKEN_EXPIRES_IN_SEC="604800"

# Database
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET_KEY="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:8080/api/auth/google/callback" # optional if APP_BASE_URL or RAILWAY_PUBLIC_DOMAIN is set

# Kakao OAuth
KAKAO_REST_API_KEY="your-kakao-rest-api-key"
KAKAO_CLIENT_SECRET_KEY="" # optional, required if Kakao client secret is enabled
KAKAO_CALLBACK_URL="http://localhost:8080/api/auth/kakao/callback" # optional if APP_BASE_URL or RAILWAY_PUBLIC_DOMAIN is set

# Railway
# RAILWAY_PUBLIC_DOMAIN is provided automatically after Generate Domain.
