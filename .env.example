# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET_KEY="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:8080/api/auth/google/callback"

# Kakao OAuth
KAKAO_REST_API_KEY="your-kakao-rest-api-key"
KAKAO_CALLBACK_URL="http://localhost:8080/api/auth/kakao/callback"

# Supabase
SUPADB_PROJECT_URL="https://your-project-ref.supabase.co"
SUPADB_PUBLISHABLE_KEY="sb_publishable_xxx"
DATABSE_PASSWD_KEY="your-database-password"

# Prisma + Supabase (optional override)
SUPADB_CONNECTION_MODE="pooler" # pooler | direct
SUPADB_REGION="ap-northeast-2"
SUPADB_DB_HOST=""
SUPADB_DB_PORT=""
SUPADB_DB_USER=""
SUPADB_DB_NAME="postgres"
SUPADB_DB_SCHEMA="public"
SUPADB_SSL_MODE="require" # require | verify-full | no-verify
SUPADB_USE_LIBPQ_COMPAT="true"


# Server
PORT="8080"
